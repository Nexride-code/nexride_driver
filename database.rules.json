{
  "rules": {
    "admins": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": false
      }
    },
    "support_staff": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": false
      }
    },
    "drivers": {
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('admins').child(auth.uid).val() === true || root.child('support_staff').child(auth.uid).val() === true)",
        ".write": "auth != null && auth.uid === $uid"
      },
      ".indexOn": ["dispatch_market", "is_online", "isOnline", "market", "city", "status", "payment_status", "created_at"]
    },
    "driver_offer_queue": {
      "$driverId": {
        ".read": "auth != null && auth.uid === $driverId",
        ".write": false,
        "$rideId": {
          ".read": "auth != null && auth.uid === $driverId",
          ".write": false
        }
      }
    },
    "ride_offer_fanout": {
      "$rideId": {
        "$driverId": {
          ".read": false,
          ".write": false
        }
      }
    },
    "active_trips": {
      "$rideId": {
        ".read": "auth != null && (data.child('rider_id').val() === auth.uid || data.child('driver_id').val() === auth.uid)",
        ".write": false
      }
    },
    "rider_active_ride": {
      "$riderId": {
        ".read": "auth != null && auth.uid === $riderId",
        ".write": false
      }
    },
    "driver_active_ride": {
      "$driverId": {
        ".read": "auth != null && auth.uid === $driverId",
        ".write": false
      }
    },
    "ride_track_public": {
      "$token": {
        ".read": true,
        ".write": false
      }
    },
    "webhook_applied": {
      "flutterwave": {
        "$txId": {
          ".read": false,
          ".write": false
        }
      }
    },
    "driver_wallet_ledger": {
      "$driverId": {
        "$entry": {
          ".read": "auth != null && auth.uid === $driverId",
          ".write": false
        }
      }
    },
    "ride_requests": {
      ".indexOn": ["market", "market_pool", "driver_id", "rider_id", "trip_state", "status", "payment_status", "created_at", "updated_at", "expires_at", "track_token"],
      "$rideId": {
        ".read": "auth != null && (data.child('rider_id').val() === auth.uid || data.child('driver_id').val() === auth.uid || (root.child('drivers/' + auth.uid).exists() && (data.child('market_pool').val() === root.child('drivers/' + auth.uid + '/dispatch_market').val() || data.child('market_pool').val() === root.child('drivers/' + auth.uid + '/market_pool').val() || data.child('market_pool').val() === root.child('drivers/' + auth.uid + '/market').val() || data.child('market_pool').val() === root.child('drivers/' + auth.uid + '/city').val() || data.child('market').val() === root.child('drivers/' + auth.uid + '/dispatch_market').val() || data.child('market').val() === root.child('drivers/' + auth.uid + '/market_pool').val() || data.child('market').val() === root.child('drivers/' + auth.uid + '/market').val() || data.child('market').val() === root.child('drivers/' + auth.uid + '/city').val()) && (data.child('driver_id').val() == null || data.child('driver_id').val() === '' || data.child('driver_id').val() === 'waiting') && (data.child('trip_state').val() === 'searching' || data.child('status').val() === 'searching' || data.child('trip_state').val() === 'requested' || data.child('status').val() === 'requesting')))",
        ".write": false
      }
    },
    "ride_chats": {
      "$rideId": {
        ".read": "auth != null && (root.child('ride_requests').child($rideId).child('rider_id').val() === auth.uid || root.child('ride_requests').child($rideId).child('driver_id').val() === auth.uid)",
        ".write": "auth != null && (root.child('ride_requests').child($rideId).child('rider_id').val() === auth.uid || root.child('ride_requests').child($rideId).child('driver_id').val() === auth.uid)"
      }
    },
    "calls": {
      ".indexOn": ["receiverId", "receiver_id", "rideId", "ride_id"],
      "$rideKey": {
        ".read": "auth != null && (root.child('ride_requests').child($rideKey).child('rider_id').val() === auth.uid || root.child('ride_requests').child($rideKey).child('driver_id').val() === auth.uid)",
        ".write": "auth != null && (root.child('ride_requests').child($rideKey).child('rider_id').val() === auth.uid || root.child('ride_requests').child($rideKey).child('driver_id').val() === auth.uid)"
      }
    },
    "users": {
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('admins').child(auth.uid).val() === true)",
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "wallets": {
      "$userId": {
        ".read": "auth != null && auth.uid === $userId",
        ".write": false
      }
    },
    "payments": {
      "$transactionId": {
        ".read": "auth != null && (!data.exists() || data.child('rider_id').val() === auth.uid || data.child('driver_id').val() === auth.uid || root.child('admins').child(auth.uid).val() === true || root.child('support_staff').child(auth.uid).val() === true)",
        ".write": false
      }
    },
    "payment_transactions": {
      "$reference": {
        ".read": "auth != null && (!data.exists() || data.child('rider_id').val() === auth.uid || data.child('driver_id').val() === auth.uid || root.child('admins').child(auth.uid).val() === true)",
        ".write": false
      }
    },
    "driver_earnings": {
      "$driverId": {
        ".read": "auth != null && auth.uid === $driverId",
        ".write": false
      }
    },
    "admin_audit_logs": {
      ".read": "auth != null && root.child('admins').child(auth.uid).val() === true",
      ".write": false
    },
    "trip_settlement_hooks": {
      "$rideId": {
        ".read": "auth != null && (root.child('ride_requests').child($rideId).child('rider_id').val() === auth.uid || root.child('ride_requests').child($rideId).child('driver_id').val() === auth.uid || root.child('admins').child(auth.uid).val() === true)",
        ".write": false
      }
    },
    "trip_route_logs": {
      "$rideId": {
        ".read": "auth != null && (root.child('ride_requests').child($rideId).child('rider_id').val() === auth.uid || root.child('ride_requests').child($rideId).child('driver_id').val() === auth.uid || root.child('admins').child(auth.uid).val() === true)",
        ".write": "auth != null && root.child('ride_requests').child($rideId).child('driver_id').val() === auth.uid"
      }
    },
    "admin_rides": {
      "$rideId": {
        ".read": "auth != null && root.child('admins').child(auth.uid).val() === true",
        ".write": false
      }
    },
    "support_queue": {
      "$rideId": {
        ".read": "auth != null && root.child('admins').child(auth.uid).val() === true",
        ".write": false
      }
    },
    "support_tickets": {
      ".indexOn": ["createdByUserId", "status", "updatedAt"],
      "$ticketId": {
        ".read": "auth != null && ((!data.exists() && false) || data.child('createdByUserId').val() === auth.uid || root.child('admins').child(auth.uid).val() === true || root.child('support_staff').child(auth.uid).val() === true)",
        ".write": "auth != null && (root.child('admins').child(auth.uid).val() === true || root.child('support_staff').child(auth.uid).val() === true || (!data.exists() && newData.child('createdByUserId').val() === auth.uid) || (data.exists() && data.child('createdByUserId').val() === auth.uid))"
      }
    },
    "support_ticket_messages": {
      "$ticketDocId": {
        "$msgId": {
          ".read": "auth != null && ((!root.child('support_tickets').child($ticketDocId).exists()) || root.child('support_tickets').child($ticketDocId).child('createdByUserId').val() === auth.uid || root.child('admins').child(auth.uid).val() === true || root.child('support_staff').child(auth.uid).val() === true)",
          ".write": "auth != null && ((!root.child('support_tickets').child($ticketDocId).exists()) || root.child('support_tickets').child($ticketDocId).child('createdByUserId').val() === auth.uid || root.child('admins').child(auth.uid).val() === true || root.child('support_staff').child(auth.uid).val() === true)"
        }
      }
    },
    "support_logs": {
      "$ticketId": {
        ".read": "auth != null && (root.child('admins').child(auth.uid).val() === true || root.child('support_staff').child(auth.uid).val() === true)",
        ".write": "auth != null && (root.child('admins').child(auth.uid).val() === true || root.child('support_staff').child(auth.uid).val() === true)"
      }
    },
    "app_config": {
      ".read": "auth != null",
      ".write": "auth != null && root.child('admins').child(auth.uid).val() === true"
    },
    "rider_reputation": {
      "$uid": {
        ".read": "auth != null",
        ".write": "auth != null && root.child('admins').child(auth.uid).val() === true"
      }
    },
    "rider_risk_flags": {
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('admins').child(auth.uid).val() === true)",
        ".write": "auth != null && root.child('admins').child(auth.uid).val() === true"
      }
    },
    "rider_payment_flags": {
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('admins').child(auth.uid).val() === true)",
        ".write": "auth != null && root.child('admins').child(auth.uid).val() === true"
      }
    },
    "rider_ratings": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "rider_reports": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "verification_checks": {
      "$checkId": {
        ".read": "auth != null && ((!data.exists()) || data.child('driverId').val() === auth.uid || root.child('admins').child(auth.uid).val() === true || root.child('support_staff').child(auth.uid).val() === true)",
        ".write": "auth != null && newData.child('driverId').val() === auth.uid"
      }
    },
    "verification_audits": {
      "$auditId": {
        ".read": "auth != null && ((!data.exists()) || data.child('driverId').val() === auth.uid || root.child('admins').child(auth.uid).val() === true || root.child('support_staff').child(auth.uid).val() === true)",
        ".write": "auth != null && newData.child('driverId').val() === auth.uid"
      }
    },
    "driver_verifications": {
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('admins').child(auth.uid).val() === true || root.child('support_staff').child(auth.uid).val() === true)",
        ".write": "auth != null && auth.uid === $uid && (!newData.child('status').exists() || (newData.child('status').val() !== 'verified' && newData.child('status').val() !== 'approved'))"
      }
    },
    "driver_documents": {
      "$uid": {
        "$docKey": {
          ".read": "auth != null && (auth.uid === $uid || root.child('admins').child(auth.uid).val() === true || root.child('support_staff').child(auth.uid).val() === true)",
          ".write": "auth != null && auth.uid === $uid && (!root.child('driver_documents').child($uid).child($docKey).exists() || !newData.child('status').exists() || (newData.child('status').val() !== 'verified' && newData.child('status').val() !== 'approved'))"
        }
      }
    },
    "driver_business_models": {
      ".read": "auth != null",
      ".write": "auth != null && root.child('admins').child(auth.uid).val() === true"
    },
    "withdraw_requests": {
      ".indexOn": ["driver_id", "driverId", "status"],
      "$key": {
        ".read": "auth != null && (!data.exists() || data.child('driver_id').val() === auth.uid || data.child('driverId').val() === auth.uid || root.child('admins').child(auth.uid).val() === true || root.child('support_staff').child(auth.uid).val() === true)",
        ".write": false
      }
    },
    "trip_safety_flags": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "trip_disputes": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "shared_trips": {
      "$token": {
        ".read": "auth != null && ((!data.exists() && false) || data.child('rider_id').val() === auth.uid || data.child('driver_id').val() === auth.uid || root.child('admins').child(auth.uid).val() === true || root.child('support_staff').child(auth.uid).val() === true)",
        ".write": false
      }
    },
    "nexride_public_config": {
      ".read": true,
      ".write": "auth != null && root.child('admins').child(auth.uid).val() === true"
    }
  }
}
