rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Chat images: ride_chats/{rideId}/{senderUid}/{fileName}
    match /ride_chats/{rideId}/{senderUid}/{fileName} {
      allow write: if request.auth != null && request.auth.uid == senderUid;
      allow read: if request.auth != null;
    }

    // Bank transfer proof screenshots (ride-scoped)
    match /ride_payment_proofs/{rideId}/{uid}/{fileName} {
      allow write: if request.auth != null && request.auth.uid == uid;
      allow read: if request.auth != null;
    }
  }
}
